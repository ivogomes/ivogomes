{
  "name": "tapscore-app",
  "version": "1.0.0",
  "private": true,
  "description": "Native iOS/Android shell for the TapScore PWA (via Capacitor).",
  "type": "module",
  "scripts": {
    "copy:web": "node copy-web.mjs",
    "sync": "npm run copy:web && cap sync",
    "open:ios": "cap open ios",
    "open:android": "cap open android",
    "run:ios": "npm run sync && cap run ios",
    "run:android": "npm run sync && cap run android",
    "assets": "npx --yes @capacitor/assets@3 generate --iconBackgroundColor '#0b1220' --splashBackgroundColor '#0b1220'"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/core": "^6.2.0",
    "@capacitor/haptics": "^6.0.2",
    "@capacitor/ios": "^6.2.0",
    "@capacitor/splash-screen": "^6.0.3",
    "@capacitor/status-bar": "^6.0.2",
    "@capacitor-community/keep-awake": "^5.0.0",
    "@capacitor-community/text-to-speech": "^5.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0"
  }
}
