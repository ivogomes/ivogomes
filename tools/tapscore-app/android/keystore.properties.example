# Copy this file to `keystore.properties` (same folder) and fill in real values.
# keystore.properties is git-ignored — never commit it or the .jks file.
#
# Create the keystore first (see README): keytool -genkeypair ...
# storeFile: absolute path is safest (keep the .jks OUTSIDE the repo).

storeFile=/Users/YOU/keystores/tapscore-release.jks
storePassword=CHANGE_ME
keyAlias=tapscore
keyPassword=CHANGE_ME
